// Prisma schema for the maarkn.dev admin CMS.
//
// Currently SQLite for a one-step Vercel deploy. JSON fields land as TEXT and
// are encoded/decoded in the application layer. Switching back to Postgres
// (via the bundled docker-compose) only requires changing `provider` to
// "postgresql" and bumping JSON columns to native Json — see README.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  year          String
  category      String
  status        String   @default("live")
  featured      Boolean  @default(false)
  monogram      String
  accentFrom    String
  accentTo      String
  /// JSON-encoded array of tech stack tags. See lib/json-list.ts.
  stackJson     String   @default("[]")
  repoUrl       String?
  demoUrl       String?
  caseUrl       String?
  /// Plain-language tagline shown on cards.
  tagline       String?
  /// Long-form description rendered on the detail page.
  description   String?
  /// Short paragraph describing Marco's role on the project.
  role          String?
  /// JSON-encoded array of bullet strings.
  featuresJson  String   @default("[]")
  /// "public" exposes the repo button when repoUrl is set; "private" hides it
  /// in favor of a "Private project" pill.
  sourceVisibility String @default("public")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([featured])
  @@index([category])
}
