# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local sqlite database
prisma/dev.db
prisma/dev.db-journal

# uploaded media (served from a volume in prod)
/uploads

# personal knowledge base — copied straight onto the server, never committed
# (see knowledge/README.md). Only the README stays under version control.
/knowledge/*
!/knowledge/README.md

# one-time backup of the pre-Postgres SQLite migrations
/prisma/migrations.sqlite.bak

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
